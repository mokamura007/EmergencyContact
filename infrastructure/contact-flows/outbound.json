    "Annotations": [],
    "name": "SafetyConfirmationOutboundFlow",
    "description": "Safety Confirmation outbound voice flow (Phase 7.1). Sets Polly ja-JP/Mizuki voice, enables full-call recording (Both sides), plays the OutboundGuidanceText TTS prompt, waits up to 30 seconds for the employee's voice response (recorded by Connect), invokes CallEndHandler Lambda (which writes Response.callResultCode=RECORDED + endedAt and calls SFN SendTaskSuccess to release the Map iteration's TaskToken), then disconnects. Substitution placeholders: ${CallEndHandlerFnArn}, ${OutboundGuidanceText}. NO_ANSWER / BUSY / VOICEMAIL / ERROR / TRANSCRIBE_FAILED classifications are NOT produced here \u2014 they are emitted outside this flow (Connect CTR EventBridge, ConnectDispatcher 6.2, TranscribeStarter 6.4, Phase 7.4 classifyCallResult). DTMF is intentionally absent per Requirement 5.6.",
    "type": "contactFlow",
    "status": "PUBLISHED",
    "hash": {}
  },
  "Actions": [
    {
      "Identifier": "01000000-0000-0000-0000-000000000001",
      "Type": "UpdateContactTextToSpeechVoice",
      "Parameters": {
        "TextToSpeechVoice": "Mizuki"
      },
      "Transitions": {
        "NextAction": "02000000-0000-0000-0000-000000000002",
        "Errors": [],
        "Conditions": []
      }
    },
    {
      "Identifier": "02000000-0000-0000-0000-000000000002",
      "Type": "UpdateContactRecordingBehavior",
      "Parameters": {
        "RecordingBehavior": "Both"
      },
      "Transitions": {
        "NextAction": "03000000-0000-0000-0000-000000000003",
        "Errors": [],
        "Conditions": []
      }
    },
    {
      "Identifier": "03000000-0000-0000-0000-000000000003",
      "Type": "MessageParticipant",
      "Parameters": {
