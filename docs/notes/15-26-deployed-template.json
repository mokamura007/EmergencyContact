    Type: AWS::Lambda::LayerVersion
    Properties:
      LayerName:
        Fn::Sub: safety-confirmation-shared-${EnvironmentName}
      Description: backend/shared/ ? Pure helper functions consumed by application
        Lambdas
      Content:
        S3Bucket: safety-confirmation-cfn-artifacts-214046906694-ap-northeast-1
        S3Key: 8fee8bf912efda282e3d566110fb8dce
      CompatibleArchitectures:
      - arm64
      CompatibleRuntimes:
      - python3.12
  AuthPreAuthFnExecutionRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName:
        Fn::Sub: safety-confirmation-auth-pre-auth-${EnvironmentName}
      AssumeRolePolicyDocument:
