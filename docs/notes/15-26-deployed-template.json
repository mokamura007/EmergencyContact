    Type: AWS::SNS::Topic
    Properties:
      TopicName:
        Fn::Sub: safety-confirmation-operator-${EnvironmentName}
      DisplayName:
        Fn::Sub: Safety Confirmation Operator (${EnvironmentName})
  OperatorEmailSubscription:
    Type: AWS::SNS::Subscription
    Properties:
      TopicArn:
        Ref: OperatorTopic
      Protocol: email
      Endpoint:
        Ref: OperatorEmail
  SLAWarning30MinAlarm:
    Type: AWS::CloudWatch::Alarm
    Properties:
      AlarmName:
        Fn::Sub: safety-confirmation-sla-warning-30min-${EnvironmentName}
      AlarmDescription: Cycle ???? 30 ??????????? 100% ?????????? (Requirement 14.5)
      Namespace: SafetyConfirmation
      MetricName: SlaWarning30Min
      Statistic: Sum
      Period: 300
      EvaluationPeriods: 1
      Threshold: 1
      ComparisonOperator: GreaterThanOrEqualToThreshold
      TreatMissingData: notBreaching
      AlarmActions:
      - Ref: OperatorTopic
  CycleTimeoutAlarm:
    Type: AWS::CloudWatch::Alarm
    Properties:
      AlarmName:
        Fn::Sub: safety-confirmation-cycle-timeout-${EnvironmentName}
      AlarmDescription: Cycle ? 60 ???????????????? (Requirements 14.4 / 14.6)
      Namespace: SafetyConfirmation
      MetricName: CycleTimeout
      Statistic: Sum
      Period: 300
      EvaluationPeriods: 1
      Threshold: 1
      ComparisonOperator: GreaterThanOrEqualToThreshold
      TreatMissingData: notBreaching
      AlarmActions:
      - Ref: OperatorTopic
  LambdaErrorsAlarm:
    Type: AWS::CloudWatch::Alarm
    Properties:
      AlarmName:
        Fn::Sub: safety-confirmation-lambda-errors-${EnvironmentName}
      AlarmDescription: ????? Lambda ??? 5 ??? 5 ????????? (????)
      Namespace: AWS/Lambda
      MetricName: Errors
      Statistic: Sum
      Period: 300
      EvaluationPeriods: 1
      Threshold: 5
      ComparisonOperator: GreaterThanOrEqualToThreshold
      TreatMissingData: notBreaching
      AlarmActions:
      - Ref: OperatorTopic
  RecordingUploadFailureAlarm:
    Type: AWS::CloudWatch::Alarm
    Properties:
      AlarmName:
        Fn::Sub: safety-confirmation-recording-upload-failure-${EnvironmentName}
      AlarmDescription: RecordingMetadataWriter ? 3 ???? DLQ ????????? (Requirement
        10.9)
      Namespace: AWS/SQS
      MetricName: NumberOfMessagesSent
      Dimensions:
      - Name: QueueName
        Value:
          Fn::GetAtt:
          - RecordingMetadataWriterDLQ
          - QueueName
      Statistic: Sum
      Period: 300
      EvaluationPeriods: 1
      Threshold: 1
      ComparisonOperator: GreaterThanOrEqualToThreshold
      TreatMissingData: notBreaching
