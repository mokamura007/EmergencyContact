      Description: Phase 15.2a CORS hotfix deployment (24 base methods + 18 OPTIONS
        + 3 GatewayResponse)
  ApiStage:
    Type: AWS::ApiGateway::Stage
    DependsOn:
    - ApiGatewayAccount
    Properties:
      RestApiId:
        Ref: RestApi
      DeploymentId:
        Ref: ApiDeploymentV2Cors
      StageName:
        Ref: EnvironmentName
      Description:
        Fn::Sub: Safety Confirmation API stage for environment ${EnvironmentName}
      AccessLogSetting:
        DestinationArn:
          Fn::GetAtt:
          - ApiGwAccessLogGroup
          - Arn
        Format: '{"requestId":"$context.requestId","sourceIp":"$context.identity.sourceIp","method":"$context.httpMethod","path":"$context.resourcePath","status":"$context.status","len":"$context.responseLength","latency":"$context.responseLatency"}'
      MethodSettings:
      - ResourcePath: /*
        HttpMethod: '*'
        LoggingLevel: INFO
        DataTraceEnabled: false
        MetricsEnabled: true
        ThrottlingRateLimit:
          Fn::FindInMap:
          - EnvMap
          - Ref: EnvironmentName
          - ApiThrottleRate
        ThrottlingBurstLimit:
          Fn::FindInMap:
          - EnvMap
          - Ref: EnvironmentName
          - ApiThrottleBurst
  SpaOac:
    Type: AWS::CloudFront::OriginAccessControl
    Properties:
      OriginAccessControlConfig:
        Name:
          Fn::Sub: ${EnvironmentName}-safety-confirmation-spa-oac
        Description:
          Fn::Sub: OAC for SPA bucket (${EnvironmentName} environment, SigV4 to S3
            origin)
        OriginAccessControlOriginType: s3
        SigningBehavior: always
        SigningProtocol: sigv4
  SpaDistribution:
    Type: AWS::CloudFront::Distribution
    Properties:
      DistributionConfig:
        Enabled: true
        Comment:
          Fn::Sub: Safety Confirmation SPA distribution (${EnvironmentName})
        DefaultRootObject: index.html
        HttpVersion: http2and3
        IPV6Enabled: true
        PriceClass: PriceClass_200
        Aliases:
          Fn::If:
          - HasCustomDomain
          - - Ref: DomainName
          - Ref: AWS::NoValue
        Origins:
        - Id: SpaS3Origin
          DomainName:
            Fn::GetAtt:
            - SpaBucket
            - RegionalDomainName
          OriginAccessControlId:
            Fn::GetAtt:
            - SpaOac
            - Id
          S3OriginConfig:
            OriginAccessIdentity: ''
        DefaultCacheBehavior:
          TargetOriginId: SpaS3Origin
          ViewerProtocolPolicy: redirect-to-https
          AllowedMethods:
          - GET
          - HEAD
          CachedMethods:
          - GET
          - HEAD
          Compress: true
          CachePolicyId: 658327ea-f89d-4fab-a63d-7e88639e58f6
        CustomErrorResponses:
        - ErrorCode: 403
          ResponseCode: 200
          ResponsePagePath: /index.html
          ErrorCachingMinTTL: 0
        - ErrorCode: 404
          ResponseCode: 200
          ResponsePagePath: /index.html
          ErrorCachingMinTTL: 0
        ViewerCertificate:
          Fn::If:
          - UseCustomCert
          - AcmCertificateArn:
              Ref: AcmCertificateArn
            SslSupportMethod: sni-only
            MinimumProtocolVersion: TLSv1.2_2021
          - CloudFrontDefaultCertificate: true
  SpaBucketPolicy:
    Type: AWS::S3::BucketPolicy
    Properties:
      Bucket:
        Ref: SpaBucket
      PolicyDocument:
        Version: '2012-10-17'
        Statement:
        - Sid: AllowCloudFrontServicePrincipalRead
          Effect: Allow
          Principal:
            Service: cloudfront.amazonaws.com
          Action: s3:GetObject
          Resource:
            Fn::Sub: ${SpaBucket.Arn}/*
          Condition:
            StringEquals:
              AWS:SourceArn:
                Fn::Sub: arn:${AWS::Partition}:cloudfront::${AWS::AccountId}:distribution/${SpaDistribution}
  SpaRecordSet:
    Type: AWS::Route53::RecordSet
    Condition: HasCustomDomainAndHostedZone
    Properties:
      HostedZoneId:
        Ref: HostedZoneId
      Name:
        Ref: DomainName
      Type: A
      AliasTarget:
        DNSName:
          Fn::GetAtt:
          - SpaDistribution
          - DomainName
        HostedZoneId: Z2FDTNDATAQYW2
        EvaluateTargetHealth: false
