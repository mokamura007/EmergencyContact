Mappings:
  EnvMap:
    dev:
      LogLevel: INFO
      DynamoBillingMode: PAY_PER_REQUEST
      ApiThrottleRate: 50
      ApiThrottleBurst: 100
    stg:
      LogLevel: INFO
      DynamoBillingMode: PAY_PER_REQUEST
      ApiThrottleRate: 100
      ApiThrottleBurst: 200
    prod:
      LogLevel: WARN
      DynamoBillingMode: PAY_PER_REQUEST
      ApiThrottleRate: 100
      ApiThrottleBurst: 200
Conditions:
  IsProd:
    Fn::Equals:
    - Ref: EnvironmentName
    - prod
  HasCustomDomain:
    Fn::Not:
    - Fn::Equals:
      - Ref: DomainName
      - ''
  UseCustomCert:
    Fn::Not:
    - Fn::Equals:
      - Ref: AcmCertificateArn
      - ''
  HasHostedZoneId:
    Fn::Not:
    - Fn::Equals:
      - Ref: HostedZoneId
      - ''
  HasCustomDomainAndHostedZone:
    Fn::And:
    - Condition: HasCustomDomain
    - Condition: HasHostedZoneId
  ManageConnectStorageConfigCond:
    Fn::Equals:
    - Ref: ManageConnectStorageConfig
    - 'true'
Resources:
  KmsCmk:
    Type: AWS::KMS::Key
    Properties:
      Description:
        Fn::Sub: '?????????? KMS CMK???: ${EnvironmentName}??DynamoDB / S3 / Lambda
          ??????????'
      KeySpec: SYMMETRIC_DEFAULT
      KeyUsage: ENCRYPT_DECRYPT
      EnableKeyRotation: true
      PendingWindowInDays: 7
      KeyPolicy:
        Version: '2012-10-17'
        Id:
          Fn::Sub: ${EnvironmentName}-safety-confirmation-key-policy
        Statement:
        - Sid: EnableIAMUserPermissions
          Effect: Allow
          Principal:
            AWS:
              Fn::Sub: arn:aws:iam::${AWS::AccountId}:root
          Action: kms:*
          Resource: '*'
  KmsCmkAlias:
    Type: AWS::KMS::Alias
    Properties:
      AliasName:
        Fn::Sub: alias/${EnvironmentName}-safety-confirmation
      TargetKeyId:
        Ref: KmsCmk
