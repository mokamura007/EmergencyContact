      - Ref: OperatorTopic
  TranscribeFailedAlarm:
    Type: AWS::CloudWatch::Alarm
    Properties:
      AlarmName:
        Fn::Sub: safety-confirmation-transcribe-failed-${EnvironmentName}
      AlarmDescription: Transcribe ???? 3 ????? (Requirement 6.6)
      Namespace: AWS/Lambda
      MetricName: Errors
      Dimensions:
      - Name: FunctionName
        Value:
          Ref: TranscribeStarterFn
      Statistic: Sum
      Period: 300
      EvaluationPeriods: 1
      Threshold: 1
      ComparisonOperator: GreaterThanOrEqualToThreshold
      TreatMissingData: notBreaching
      AlarmActions:
      - Ref: OperatorTopic
  InboundUnauthorizedFilter:
    Type: AWS::Logs::MetricFilter
    Properties:
      LogGroupName:
        Ref: AuditLogGroup
      FilterName:
        Fn::Sub: safety-confirmation-inbound-unauthorized-${EnvironmentName}
      FilterPattern: '{ $.event = "INBOUND_CONTACT_RECEIVED" && $.flow = "NOT_REGISTERED"
        }'
      MetricTransformations:
      - MetricNamespace: SafetyConfirmation
        MetricName: InboundUnauthorized
        MetricValue: '1'
        DefaultValue: 0
  InboundUnauthorizedAlarm:
    Type: AWS::CloudWatch::Alarm
    DependsOn: InboundUnauthorizedFilter
    Properties:
      AlarmName:
        Fn::Sub: safety-confirmation-inbound-unauthorized-${EnvironmentName}
      AlarmDescription: ???????? inbound ??? 5 ??? 10 ????? (Out of Scope 9 ?? / brute
        force ???)
      Namespace: SafetyConfirmation
      MetricName: InboundUnauthorized
      Statistic: Sum
      Period: 300
      EvaluationPeriods: 1
      Threshold: 10
      ComparisonOperator: GreaterThanOrEqualToThreshold
      TreatMissingData: notBreaching
      AlarmActions:
      - Ref: OperatorTopic
  EmployeeTable:
    Type: AWS::DynamoDB::Table
    Properties:
      TableName:
        Fn::Sub: Employee-${EnvironmentName}
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
      - AttributeName: employeeId
        AttributeType: S
      - AttributeName: phoneNumber
        AttributeType: S
      KeySchema:
      - AttributeName: employeeId
        KeyType: HASH
      GlobalSecondaryIndexes:
      - IndexName: PhoneNumberIndex
        KeySchema:
        - AttributeName: phoneNumber
          KeyType: HASH
        Projection:
          ProjectionType: ALL
      SSESpecification:
        SSEEnabled: true
        SSEType: KMS
        KMSMasterKeyId:
          Ref: KmsCmk
      PointInTimeRecoverySpecification:
        PointInTimeRecoveryEnabled: true
  CycleTable:
    Type: AWS::DynamoDB::Table
    Properties:
      TableName:
        Fn::Sub: Cycle-${EnvironmentName}
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
      - AttributeName: cycleId
        AttributeType: S
      - AttributeName: status
        AttributeType: S
      - AttributeName: startedAt
        AttributeType: S
      KeySchema:
      - AttributeName: cycleId
        KeyType: HASH
      GlobalSecondaryIndexes:
      - IndexName: StatusStartedAtIndex
        KeySchema:
        - AttributeName: status
          KeyType: HASH
        - AttributeName: startedAt
          KeyType: RANGE
        Projection:
          ProjectionType: ALL
      SSESpecification:
        SSEEnabled: true
        SSEType: KMS
        KMSMasterKeyId:
          Ref: KmsCmk
      PointInTimeRecoverySpecification:
        PointInTimeRecoveryEnabled: true
  ResponseTable:
    Type: AWS::DynamoDB::Table
    Properties:
      TableName:
        Fn::Sub: Response-${EnvironmentName}
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
      - AttributeName: cycleId
        AttributeType: S
      - AttributeName: employeeId
        AttributeType: S
      - AttributeName: contactId
        AttributeType: S
      KeySchema:
      - AttributeName: cycleId
        KeyType: HASH
      - AttributeName: employeeId
        KeyType: RANGE
      GlobalSecondaryIndexes:
      - IndexName: ContactIdIndex
        KeySchema:
        - AttributeName: contactId
          KeyType: HASH
        Projection:
          ProjectionType: INCLUDE
          NonKeyAttributes:
          - cycleId
          - employeeId
          - callAttempts
      SSESpecification:
        SSEEnabled: true
        SSEType: KMS
        KMSMasterKeyId:
          Ref: KmsCmk
      PointInTimeRecoverySpecification:
        PointInTimeRecoveryEnabled: true
  RecordingMetaTable:
    Type: AWS::DynamoDB::Table
    Properties:
      TableName:
        Fn::Sub: RecordingMetadata-${EnvironmentName}
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
      - AttributeName: cycleId
        AttributeType: S
      - AttributeName: employeeIdSeq
        AttributeType: S
      KeySchema:
      - AttributeName: cycleId
        KeyType: HASH
      - AttributeName: employeeIdSeq
        KeyType: RANGE
      SSESpecification:
        SSEEnabled: true
        SSEType: KMS
        KMSMasterKeyId:
          Ref: KmsCmk
      PointInTimeRecoverySpecification:
        PointInTimeRecoveryEnabled: true
  TranscriptMetaTable:
    Type: AWS::DynamoDB::Table
    Properties:
      TableName:
        Fn::Sub: TranscriptMetadata-${EnvironmentName}
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
      - AttributeName: cycleId
        AttributeType: S
      - AttributeName: employeeIdSeq
        AttributeType: S
      KeySchema:
      - AttributeName: cycleId
        KeyType: HASH
      - AttributeName: employeeIdSeq
        KeyType: RANGE
      SSESpecification:
        SSEEnabled: true
        SSEType: KMS
        KMSMasterKeyId:
          Ref: KmsCmk
      PointInTimeRecoverySpecification:
        PointInTimeRecoveryEnabled: true
  KeywordDictionaryTable:
    Type: AWS::DynamoDB::Table
    Properties:
      TableName:
        Fn::Sub: KeywordDictionary-${EnvironmentName}
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
      - AttributeName: category
        AttributeType: S
      - AttributeName: keyword
        AttributeType: S
      KeySchema:
      - AttributeName: category
        KeyType: HASH
      - AttributeName: keyword
        KeyType: RANGE
      SSESpecification:
        SSEEnabled: true
        SSEType: KMS
        KMSMasterKeyId:
          Ref: KmsCmk
      PointInTimeRecoverySpecification:
        PointInTimeRecoveryEnabled: true
  KeywordDictionaryHistoryTable:
    Type: AWS::DynamoDB::Table
    Properties:
      TableName:
        Fn::Sub: KeywordDictionaryHistory-${EnvironmentName}
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
      - AttributeName: version
        AttributeType: N
      - AttributeName: categoryKeyword
        AttributeType: S
      KeySchema:
      - AttributeName: version
        KeyType: HASH
      - AttributeName: categoryKeyword
        KeyType: RANGE
      SSESpecification:
        SSEEnabled: true
        SSEType: KMS
        KMSMasterKeyId:
          Ref: KmsCmk
      PointInTimeRecoverySpecification:
        PointInTimeRecoveryEnabled: true
  InboundContactTable:
    Type: AWS::DynamoDB::Table
    Properties:
      TableName:
        Fn::Sub: InboundContact-${EnvironmentName}
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
      - AttributeName: contactId
        AttributeType: S
      - AttributeName: employeeId
        AttributeType: S
      - AttributeName: receivedAt
        AttributeType: S
      KeySchema:
      - AttributeName: contactId
        KeyType: HASH
      GlobalSecondaryIndexes:
      - IndexName: EmployeeReceivedAtIndex
        KeySchema:
        - AttributeName: employeeId
          KeyType: HASH
        - AttributeName: receivedAt
          KeyType: RANGE
        Projection:
          ProjectionType: ALL
      SSESpecification:
        SSEEnabled: true
        SSEType: KMS
        KMSMasterKeyId:
          Ref: KmsCmk
      PointInTimeRecoverySpecification:
        PointInTimeRecoveryEnabled: true
  LockoutTable:
    Type: AWS::DynamoDB::Table
    Properties:
      TableName:
        Fn::Sub: Lockout-${EnvironmentName}
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
      - AttributeName: userIdentifier
        AttributeType: S
      KeySchema:
      - AttributeName: userIdentifier
        KeyType: HASH
      TimeToLiveSpecification:
        AttributeName: expireAt
        Enabled: true
      SSESpecification:
        SSEEnabled: true
        SSEType: KMS
        KMSMasterKeyId:
          Ref: KmsCmk
      PointInTimeRecoverySpecification:
        PointInTimeRecoveryEnabled: true
  RecordingsBucket:
    Type: AWS::S3::Bucket
    Properties:
      BucketName:
        Fn::Sub: safety-confirmation-recordings-${EnvironmentName}-${AWS::AccountId}-${AWS::Region}
      BucketEncryption:
        ServerSideEncryptionConfiguration:
        - ServerSideEncryptionByDefault:
            SSEAlgorithm: aws:kms
            KMSMasterKeyID:
              Ref: KmsCmk
          BucketKeyEnabled: true
      PublicAccessBlockConfiguration:
        BlockPublicAcls: true
        BlockPublicPolicy: true
        IgnorePublicAcls: true
        RestrictPublicBuckets: true
      LifecycleConfiguration:
        Rules:
        - Id: DeleteRecordingsAfter90Days
          Status: Enabled
          ExpirationInDays:
            Ref: RecordingsRetentionDays
      NotificationConfiguration:
        EventBridgeConfiguration:
          EventBridgeEnabled: true
  TranscriptsBucket:
    Type: AWS::S3::Bucket
    Properties:
      BucketName:
        Fn::Sub: safety-confirmation-transcripts-${EnvironmentName}-${AWS::AccountId}-${AWS::Region}
      BucketEncryption:
        ServerSideEncryptionConfiguration:
        - ServerSideEncryptionByDefault:
            SSEAlgorithm: aws:kms
            KMSMasterKeyID:
              Ref: KmsCmk
          BucketKeyEnabled: true
      PublicAccessBlockConfiguration:
        BlockPublicAcls: true
        BlockPublicPolicy: true
        IgnorePublicAcls: true
        RestrictPublicBuckets: true
      LifecycleConfiguration:
        Rules:
        - Id: DeleteTranscriptsAfter90Days
          Status: Enabled
          ExpirationInDays:
            Ref: TranscriptsRetentionDays
      NotificationConfiguration:
        EventBridgeConfiguration:
          EventBridgeEnabled: true
  SpaBucket:
    Type: AWS::S3::Bucket
    Properties:
      BucketName:
        Fn::Sub: safety-confirmation-spa-${EnvironmentName}-${AWS::AccountId}-${AWS::Region}
      BucketEncryption:
        ServerSideEncryptionConfiguration:
        - ServerSideEncryptionByDefault:
            SSEAlgorithm: AES256
      PublicAccessBlockConfiguration:
        BlockPublicAcls: true
        BlockPublicPolicy: true
        IgnorePublicAcls: true
        RestrictPublicBuckets: true
      VersioningConfiguration:
        Status: Enabled
      LifecycleConfiguration:
        Rules:
        - Id: DeleteOldSpaVersions
          Status: Enabled
          NoncurrentVersionExpirationInDays: 30
  CognitoUserPool:
    Type: AWS::Cognito::UserPool
    Properties:
      UserPoolName:
        Fn::Sub: safety-confirmation-${EnvironmentName}
      AdminCreateUserConfig:
        AllowAdminCreateUserOnly: true
      UsernameAttributes:
      - email
      AutoVerifiedAttributes:
      - email
      MfaConfiguration: 'OFF'
      Policies:
        PasswordPolicy:
          MinimumLength: 12
          RequireUppercase: true
          RequireLowercase: true
          RequireNumbers: true
          RequireSymbols: true
          TemporaryPasswordValidityDays: 7
      Schema:
      - Name: name
        AttributeDataType: String
        Required: true
        Mutable: true
      AccountRecoverySetting:
        RecoveryMechanisms:
        - Name: admin_only
          Priority: 1
      UserPoolTags:
        Project: safety-confirmation
        Environment:
          Ref: EnvironmentName
      LambdaConfig:
        PreAuthentication:
          Fn::GetAtt:
          - AuthPreAuthFn
          - Arn
        PostAuthentication:
          Fn::GetAtt:
          - AuthPostAuthFn
          - Arn
        PreSignUp:
          Fn::GetAtt:
          - AuthPreSignUpFn
          - Arn
  CognitoUserPoolClient:
    Type: AWS::Cognito::UserPoolClient
    Properties:
      UserPoolId:
        Ref: CognitoUserPool
      ClientName:
        Fn::Sub: safety-confirmation-spa-${EnvironmentName}
      GenerateSecret: false
      ExplicitAuthFlows:
      - ALLOW_USER_SRP_AUTH
      - ALLOW_REFRESH_TOKEN_AUTH
      PreventUserExistenceErrors: ENABLED
      EnableTokenRevocation: true
      SupportedIdentityProviders:
      - COGNITO
      IdTokenValidity: 1
      AccessTokenValidity: 1
      RefreshTokenValidity: 30
      TokenValidityUnits:
        IdToken: hours
        AccessToken: hours
        RefreshToken: days
  AdminGroup:
    Type: AWS::Cognito::UserPoolGroup
    Properties:
      UserPoolId:
        Ref: CognitoUserPool
      GroupName: Administrator
      Description: ???????????????Requirement 1.9 ??? Employee ???????????
      Precedence: 1
