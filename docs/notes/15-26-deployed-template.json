    Type: AWS::IAM::ManagedPolicy
    Properties:
      ManagedPolicyName:
        Fn::Sub: ${EnvironmentName}-safety-confirmation-lambda-base-logs
      Description:
        Fn::Sub: '? Lambda ?? CloudWatch Logs ?????????? (??: ${EnvironmentName})????
          Role ? ManagedPolicyArns ????????????'
      PolicyDocument:
        Version: '2012-10-17'
        Statement:
        - Sid: AllowCreateLogGroup
          Effect: Allow
          Action: logs:CreateLogGroup
          Resource:
            Fn::Sub: arn:aws:logs:${AWS::Region}:${AWS::AccountId}:*
        - Sid: AllowWriteLambdaLogStreams
          Effect: Allow
          Action:
          - logs:CreateLogStream
          - logs:PutLogEvents
          Resource:
            Fn::Sub: arn:aws:logs:${AWS::Region}:${AWS::AccountId}:log-group:/aws/lambda/*:*
  AuditLogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName:
        Fn::Sub: /aws/safety-confirmation/audit-${EnvironmentName}
      RetentionInDays:
        Ref: LogRetentionDays
  AuditLogWriteManagedPolicy:
    Type: AWS::IAM::ManagedPolicy
    Properties:
      ManagedPolicyName:
        Fn::Sub: ${EnvironmentName}-safety-confirmation-audit-log-write
      Description:
        Fn::Sub: 'Phase 12.3: AuditLogGroup ???? (??: ${EnvironmentName})?auth / dictionary
          / employee / cycle / inbound 6 Lambda ? Role ??????'
      PolicyDocument:
        Version: '2012-10-17'
        Statement:
        - Sid: AllowAuditLogWrite
          Effect: Allow
          Action:
          - logs:DescribeLogStreams
          - logs:CreateLogStream
          - logs:PutLogEvents
          Resource:
            Fn::GetAtt:
            - AuditLogGroup
            - Arn
  AuditReaderManagedPolicy:
    Type: AWS::IAM::ManagedPolicy
    Properties:
      ManagedPolicyName:
        Fn::Sub: ${EnvironmentName}-safety-confirmation-audit-log-read
      Description:
        Fn::Sub: 'Phase 15.15: AuditLogGroup ???? (??: ${EnvironmentName})???????
          IAM User / Role / Group ? AWS Console / CLI ????????? CloudWatch Logs Insights
          ????????'
