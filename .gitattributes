# Default: text files use LF, auto-detect text vs binary
* text=auto eol=lf

# Source code (LF)
*.py text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.sh text eol=lf

# Documentation (LF)
*.md text eol=lf
*.txt text eol=lf

# Windows-specific scripts (CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files (no text conversion, no diff)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.zip binary
*.tar binary
*.tar.gz binary
*.tgz binary
*.gz binary
*.7z binary
*.wav binary
*.mp3 binary
*.mp4 binary
*.pdf binary
*.xlsx binary
*.docx binary
*.pptx binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
