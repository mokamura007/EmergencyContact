# Safety Confirmation System - Frontend Environment Variables
#
# Copy this file to `.env.local` for local development and fill in real values.
# All client-side variables MUST be prefixed with `VITE_` (Vite convention).
# Reference: NFR3 (HTTPS / Cognito 認証) / tasks.md 10.1

# Base URL of the API Gateway stage (no trailing slash).
# Example (dev): https://abc123.execute-api.ap-northeast-1.amazonaws.com/dev
VITE_API_BASE_URL=

# Cognito User Pool ID (region prefix + 9-char suffix).
# Example: ap-northeast-1_abc123XYZ
VITE_COGNITO_USER_POOL_ID=

# Cognito User Pool App Client ID (SPA client, no client secret).
VITE_COGNITO_CLIENT_ID=

# AWS region. Optional; defaults to ap-northeast-1 in code if unset.
VITE_AWS_REGION=ap-northeast-1
